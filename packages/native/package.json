{
  "name": "@vscode-links/native",
  "type": "module",
  "version": "0.1.1",
  "private": true,
  "description": "N-API binding around the Rust vscode-links-core. Drop-in resolve() for the VSIX, the picker, or any other Node consumer that wants the native code path.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/yunsii/vscode-links#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunsii/vscode-links",
    "directory": "packages/native"
  },
  "bugs": {
    "url": "https://github.com/yunsii/vscode-links/issues"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "files": [
    "*.node",
    "index.cjs",
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "build": "node ./build-native.js",
    "test": "vitest --run --passWithNoTests"
  }
}
