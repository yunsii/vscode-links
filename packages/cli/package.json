{
  "name": "@vscode-links/cli",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone CLI for vscode-links: resolves project links from a cwd + .vscode/settings.json without VS Code.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "vscode-links": "./dist/cli.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:dts",
    "build:js": "tsdown src/cli.ts src/lib.ts",
    "build:dts": "tsc --project tsconfig.build.json",
    "test": "vitest --run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vscode-links/core": "workspace:*",
    "jsonc-parser": "^3.3.1"
  }
}
