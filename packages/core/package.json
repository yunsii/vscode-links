{
  "name": "@vscode-links/core",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Provider parsing, template rendering, and CSV resolution shared by the vscode-links VSIX and the standalone CLI.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:dts",
    "build:js": "tsdown src/index.ts",
    "build:dts": "tsc --project tsconfig.build.json",
    "test": "vitest --run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.16",
    "axios": "^1.11.0",
    "papaparse": "^5.5.3",
    "simple-git": "^3.28.0",
    "type-fest": "^4.41.0"
  }
}
