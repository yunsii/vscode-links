{
  "publisher": "yuns",
  "name": "links",
  "displayName": "Links",
  "version": "1.1.0",
  "private": true,
  "description": "Pursue better UX for project links",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "funding": "https://opencollective.com/yunsii",
  "homepage": "https://github.com/yunsii/vscode-links#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunsii/vscode-links",
    "directory": "packages/vsix"
  },
  "bugs": {
    "url": "https://github.com/yunsii/vscode-links/issues"
  },
  "sponsor": {
    "url": "https://opencollective.com/yunsii"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/**",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Links",
      "properties": {
        "links.resources": {
          "description": "Local resources to open",
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": [
              "url",
              "title"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "Specific URL"
              },
              "title": {
                "type": "string",
                "description": "Title of specific URL"
              },
              "description": {
                "type": "string",
                "description": "Description of specific URL"
              }
            }
          }
        },
        "links.remoteResources": {
          "oneOf": [
            {
              "type": "null",
              "default": null,
              "description": "Not configured (default)"
            },
            {
              "type": "object",
              "required": [
                "url"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "description": "Remote CSV file URL"
                },
                "project": {
                  "type": "string",
                  "description": "Project name, used to filter resources"
                }
              }
            }
          ],
          "description": "Remote resources to open: set to an object with `url` and `project`. Leave unset (null) to disable."
        },
        "links.customIcons": {
          "type": "object",
          "description": "Custom icons for different link types",
          "properties": {
            "local": {
              "type": "string",
              "default": "folder",
              "description": "Icon for local links"
            },
            "detected": {
              "type": "string",
              "default": "eye",
              "description": "Icon for auto-detected links"
            },
            "remote-project": {
              "type": "string",
              "default": "repo",
              "description": "Icon for remote project links"
            },
            "remote-shared": {
              "type": "string",
              "default": "share",
              "description": "Icon for shared remote links"
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "links.openPicker",
        "title": "Links: Open Picker"
      },
      {
        "command": "links.refresh",
        "title": "Links: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "links.enterSearch",
        "title": "Links: Enter Search Mode",
        "icon": "$(search)"
      },
      {
        "command": "links.exitSearch",
        "title": "Links: Exit Search Mode",
        "icon": "$(close)"
      },
      {
        "command": "links.openUrl",
        "title": "Links: Open Link"
      },
      {
        "command": "links.copyUrl",
        "title": "Links: Copy Link URL"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "linksView",
          "title": "Links",
          "icon": "res/icon-activitybar.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "linksTree",
          "name": "Links",
          "contextualTitle": "Links",
          "icon": "res/icon.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "links.enterSearch",
          "when": "false"
        },
        {
          "command": "links.exitSearch",
          "when": "false"
        },
        {
          "command": "links.openUrl",
          "when": "false"
        },
        {
          "command": "links.copyUrl",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "links.refresh",
          "when": "view == linksTree",
          "group": "navigation"
        },
        {
          "command": "links.enterSearch",
          "when": "view == linksTree && !links.isSearchMode",
          "group": "navigation"
        },
        {
          "command": "links.exitSearch",
          "when": "view == linksTree && links.isSearchMode",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "links.copyUrl",
          "when": "view == linksTree && viewItem == linkItem",
          "group": "7_modification@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "build:native": "node ./scripts/build-native.mjs",
    "dev": "pnpm run build --watch --sourcemap",
    "package": "vsce package --no-dependencies",
    "package:host": "pnpm run build && pnpm run build:native && pnpm run package",
    "publish": "vsce publish --no-dependencies",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:preview": "tsgo --noEmit",
    "update": "vscode-ext-gen --output src/generated/meta.ts",
    "prepare": "pnpm run update"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.4.0",
    "ovsx": "^0.10.5",
    "reactive-vscode": "^0.3.2",
    "vscode-ext-gen": "^1.1.0"
  }
}
