{
  "name": "vscode-links-monorepo",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "description": "Pursue better UX for project links",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "funding": "https://opencollective.com/yunsii",
  "homepage": "https://github.com/yunsii/vscode-links#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunsii/vscode-links"
  },
  "bugs": {
    "url": "https://github.com/yunsii/vscode-links/issues"
  },
  "sponsor": {
    "url": "https://opencollective.com/yunsii"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:native": "pnpm --filter ./packages/vsix run build:native",
    "dev": "pnpm --filter ./packages/vsix run dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "pnpm -r run test",
    "test:watch": "pnpm --filter ./packages/vsix run test:watch",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:preview": "pnpm -r run typecheck:preview",
    "release:cli": "node scripts/bump.mjs --train cli --to",
    "release:native": "node scripts/bump.mjs --train native --to",
    "release:vsix": "node scripts/bump.mjs --train vsix --to",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint-react/eslint-plugin": "^1.49.0",
    "@jannajs/lint": "^3.1.1",
    "@prettier/plugin-xml": "^3.4.1",
    "@types/node": "^22.15.18",
    "@typescript/native-preview": "7.0.0-dev.20250910.1",
    "bumpp": "^10.1.1",
    "eslint": "9.27.0",
    "eslint-plugin-format": "^0.1.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "pnpm": "^10.11.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.14.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "pnpm": {
    "overrides": {
      "uuid": "^14.0.0"
    }
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
